{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "AIIA Console",
  "version": "0.2.2",
  "identifier": "com.aiia.console",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "AIIA Console",
        "width": 900,
        "height": 700
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/aiia-brain"
    ],
    "macOS": {
      "signingIdentity": "Developer ID Application: Code Word Technologies Inc. (2SA8HN3DMZ)",
      "hardenedRuntime": true,
      "entitlements": "Entitlements.plist",
      "minimumSystemVersion": "10.13"
    }
  }
}
